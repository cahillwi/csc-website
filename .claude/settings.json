{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(scripts/lint-changed.sh*)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-worktree.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-lint.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": ".claude/hooks/gitleaks-scan.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-worktree-path.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-ci-before-pr.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/warn-pr-to-main.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-worktree.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-cross-worktree.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-worktree.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-cross-worktree.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-env-read.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git worktree remove:*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-worktree-cleanup.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wsl-crash-recovery.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/task-setup-workflow.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/remind-success-prompt.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/qa-review-prompt.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/agent-review-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
